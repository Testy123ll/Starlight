rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default security rule: deny all writes, allow reads if authenticated (fail-safe)
    match /{document=**} {
      allow read, write: if false;
    }

    // Products:
    // Anyone can read active products (for catalog)
    // Only authenticated admins can write/delete/update
    match /products/{productId} {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Quotes:
    // Anyone can create a new quote (anonymous or logged in)
    // Users can only read their own quotes (not implemented in UI but good practice)
    // Admins can read and update all quotes
    match /quotes/{quoteId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Inventory Logs:
    // Only admins can see and write to inventory history logs
    match /inventoryLogs/{logId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
